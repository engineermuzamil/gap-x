{
  "name": "gap-x",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "test": "npm run test:frontend && npm run test:backend",
    "lint": "eslint .",
    "format": "prettier --write .",
    "fix": "eslint --fix .",
    "typecheck": "tsc --noEmit && tsc --noEmit --project inertia/tsconfig.json",
    "test:frontend": "jest",
    "test:backend": "c8 --config .c8rc.json node ace test unit"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#transformers/*": "./app/transformers/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#tests/*": "./tests/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/api-client": "^3.2.1",
    "@japa/assert": "^4.2.0",
    "@japa/browser-client": "^2.3.0",
    "@japa/expect": "^3.0.7",
    "@japa/plugin-adonisjs": "^5.2.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@swc/core": "^1.15.30",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/luxon": "^3.7.1",
    "@types/node": "~25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "c8": "^11.0.0",
    "eslint": "^10.2.0",
    "hot-hook": "^1.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-maintained": "^10.9.6",
    "typescript": "~6.0.2",
    "vite": "^7.3.1",
    "youch": "^4.1.1"
  },
  "dependencies": {
    "@adonisjs/ally": "^6.3.0",
    "@adonisjs/auth": "^10.1.0",
    "@adonisjs/core": "^7.3.1",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/inertia": "^4.2.0",
    "@adonisjs/lucid": "^22.4.2",
    "@adonisjs/session": "^8.1.0",
    "@adonisjs/shield": "^9.0.0",
    "@adonisjs/static": "^2.0.1",
    "@adonisjs/vite": "^5.1.0",
    "@inertiajs/react": "^2.3.18",
    "@tuyau/core": "^1.2.2",
    "@vinejs/vine": "^4.3.1",
    "better-sqlite3": "^12.9.0",
    "cloudinary": "^2.9.0",
    "date-fns": "^4.1.0",
    "edge.js": "^6.5.0",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "luxon": "^3.7.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "reflect-metadata": "^0.2.2",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
